{
  "name": "sidra",
  "productName": "Sidra",
  "version": "0.3.2",
  "description": "An elegant Apple Music desktop client for Linux, macOS and Windows. No frippery, just quality. A better class of Cider 🍎",
  "main": "dist/main.js",
  "scripts": {
    "start": "npm run build && electron .",
    "build": "tsc",
    "dist": "electron-builder",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "Martin Wimpress <code@wimpress.io>",
  "homepage": "https://github.com/wimpysworld/sidra",
  "license": "BlueOak-1.0.0",
  "type": "commonjs",
  "devDependencies": {
    "electron": "github:castlabs/electron-releases#v40.8.6+wvcus",
    "electron-builder": "^26.8.2",
    "shx": "^0.4.0",
    "typescript": "^6.x",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@holusion/dbus-next": "^0.11.2",
    "@xhayper/discord-rpc": "^1.3.3",
    "electron-conf": "^1.3.0",
    "electron-log": "^5.x",
    "electron-updater": "^6.8.3"
  },
  "overrides": {
    "brace-expansion": ">=5.0.5",
    "undici": ">=6.24.0"
  },
  "build": {
    "appId": "world.wimpys.sidra",
    "productName": "Sidra",
    "copyright": "Copyright (c) Martin Wimpress",
    "publish": {
      "provider": "github",
      "owner": "wimpysworld",
      "repo": "sidra"
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "asar": true,
    "asarUnpack": [
      "assets/icons/**",
      "assets/catppuccin.css",
      "assets/locales/about.json",
      "assets/locales/loading.json",
      "assets/locales/tray.json",
      "assets/locales/update.json",
      "assets/musicKitHook.js",
      "assets/navigationBar.js",
      "assets/about.html",
      "assets/sidra-logo.png",
      "assets/splash.html",
      "assets/styleFix.css"
    ],
    "icon": "build/icon.png",
    "files": [
      "dist/**/*",
      "assets/**/*",
      "!assets/source/**"
    ],
    "directories": {
      "output": "release"
    },
    "electronDownload": {
      "mirror": "https://github.com/castlabs/electron-releases/releases/download/v"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "category": "Audio",
      "executableName": "sidra"
    },
    "appImage": {
      "artifactName": "${productName}-${os}-${arch}.${ext}"
    },
    "deb": {
      "maintainer": "Martin Wimpress <code@wimpress.io>",
      "priority": "optional"
    },
    "rpm": {
      "vendor": "Martin Wimpress"
    },
    "afterPack": "build/afterPack.cjs",
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.music",
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "background": "build/background.png",
      "window": {
        "width": 540,
        "height": 380
      },
      "iconSize": 80,
      "contents": [
        {
          "x": 140,
          "y": 150
        },
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
