{
  "name": "sidra",
  "version": "0.1.0",
  "description": "An elegant Apple Music desktop client. No frippery, just quality. A better class of Cider 🍎",
  "main": "dist/main.js",
  "scripts": {
    "start": "npm run build && electron .",
    "build": "tsc",
    "dist": "electron-builder",
    "watch": "tsc --watch"
  },
  "author": "Martin Wimpress <code@wimpress.io>",
  "homepage": "https://github.com/wimpysworld/sidra",
  "license": "BlueOak-1.0.0",
  "type": "commonjs",
  "devDependencies": {
    "electron": "github:castlabs/electron-releases#v40.7.0+wvcus",
    "electron-builder": "^26.8.2",
    "typescript": "^5.x"
  },
  "dependencies": {
    "electron-log": "^5.x"
  },
  "build": {
    "appId": "world.wimpys.sidra",
    "productName": "Sidra",
    "copyright": "Copyright (c) Martin Wimpress",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "asar": true,
    "icon": "build/icon.png",
    "files": ["dist/**/*"],
    "directories": {
      "output": "release"
    },
    "electronDownload": {
      "mirror": "https://github.com/castlabs/electron-releases/releases/download/v"
    },
    "linux": {
      "target": ["AppImage", "deb", "rpm"],
      "category": "Audio",
      "executableName": "sidra"
    },
    "deb": {
      "maintainer": "Martin Wimpress <code@wimpress.io>",
      "priority": "optional"
    },
    "rpm": {
      "vendor": "Martin Wimpress"
    },
    "afterPack": "build/afterPack.cjs",
    "mac": {
      "target": ["dmg"],
      "icon": "build/icon.icns",
      "category": "public.app-category.music",
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "background": "build/background.png",
      "window": {
        "width": 540,
        "height": 380
      },
      "iconSize": 80,
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
